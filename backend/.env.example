AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your_account_name>;AccountKey=<your_account_key>;EndpointSuffix=core.windows.net
KEY_VAULT_URL=https://<your-key-vault-name>.vault.azure.net/

# Optional: tradability score weights (defaults to 0.25 each)
TRADABILITY_WEIGHT_VOLUME=0.25
TRADABILITY_WEIGHT_OPEN_INTEREST=0.25
TRADABILITY_WEIGHT_BID_ASK_SPREAD=0.25
TRADABILITY_WEIGHT_IMPLIED_VOLATILITY=0.25
